# Kotrac WhatsApp Agent — Template de Variáveis de Ambiente
# Copie este arquivo como .env e preencha com seus dados:
#   cp .env.example .env

# ── Anthropic API ──────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Provedor de WhatsApp ───────────────────────────────────
WHATSAPP_PROVIDER=twilio

# ── Twilio ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Servidor ───────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development

# ── Banco de dados ─────────────────────────────────────────
# Local (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./kotrac_agent.db
# Produção (PostgreSQL no Railway):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
